<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Shaw IMAX Availability</title>
  <style>
    body { font-family: system-ui, sans-serif; font-size: 0.9rem; max-width: 1100px; margin: 2rem auto; padding: 0 1rem; }
    .table-scroll { overflow-x: auto; margin-bottom: 1.5rem; }
    table { border-collapse: collapse; width: 100%; min-width: 700px; }
    th, td { border: 1px solid #ddd; padding: 0.4rem 0.6rem; text-align: left; }
    th { background: #f4f4f4; }
    tbody tr:hover { background: #f9fafb; }
    td.cell-time { text-align: right; font-variant-numeric: tabular-nums; }
    td.cell-book { text-align: center; padding: 0.3rem; }
    td.cell-book a {
      display: inline-block;
      padding: 0.3rem 0.9rem;
      background: #2563eb;
      color: #fff;
      font-weight: 600;
      border-radius: 4px;
      text-decoration: none;
    }
    td.cell-book a:hover { background: #1d4ed8; }
    tbody tr.row-clicked { background: #fff7e6; }
    tbody tr.row-clicked:hover { background: #fdecc8; }
    tbody tr.row-clicked td:first-child {
      box-shadow: inset 4px 0 0 0 #b45309;
    }
    h2 { margin-top: 2rem; }
    #venue-filter { display: flex; flex-wrap: wrap; gap: 0.6rem 1.2rem; margin: 1rem 0; }
    #venue-filter label { display: inline-flex; align-items: center; gap: 0.35rem; }
    tr[data-venue].venue-hidden { display: none; }
  </style>
</head>
<body>
  {% macro cell(content, css_class="", style="") %}<td{% if css_class %} class="{{ css_class }}"{% endif %}{% if style %} style="{{ style }}"{% endif %}>{{ content }}</td>{% endmacro %}

  {% macro book_cell(url) %}<td class="cell-book"><a href="{{ url }}" target="_blank" rel="noopener noreferrer">Book</a></td>{% endmacro %}

  {% macro show_table_head(show_date=True) %}
  <thead>
    <tr>
      {% if show_date %}<th>Date</th>{% endif %}<th>Movie</th><th>Venue</th><th>Time</th><th>Availability</th>
      <th>Seats</th><th>Status</th><th>Best Seats</th><th>Book</th>
    </tr>
  </thead>
  {% endmacro %}

  {% macro show_row(show) %}
  <tr data-performance-id="{{ show.performance_id }}" data-venue="{{ show.venue_name }}" data-availability="{{ show.availability_pct }}" data-date-label="{{ short_date(show.display_date) }}">
    {{ cell(show.movie_title) }}
    {{ cell(show.venue_name) }}
    {{ cell(show.display_time, "cell-time") }}
    {{ cell("%.1f%%"|format(show.availability_pct), style=availability_style(show.availability_pct)) }}
    {{ cell(show.available ~ "/" ~ show.total_seats) }}
    {{ cell(status_label(show.api_seating_status)) }}
    {{ cell(show.best_seats_available|join(", ") if show.best_seats_available else "-") }}
    {{ book_cell(booking_url(show.performance_id)) }}
  </tr>
  {% endmacro %}

  <h1>Shaw IMAX Availability Report</h1>
  <p>Generated: {{ generated_at_display }}</p>
  <p>Updated every 30 minutes, 7:00am&ndash;11:00pm SGT.</p>

  <p>
    Scan window:
    {{ report.dates_scanned[0] if report.dates_scanned else "n/a" }}
    to
    {{ report.dates_scanned[-1] if report.dates_scanned else "n/a" }}
    ({{ report.dates_scanned|length }} day(s) scanned, stopped: {{ report.stop_reason }})<br>
    Total showtimes collected: {{ report.total_shows }}<br>
    Failed API calls: {{ report.failed_calls|length }}
  </p>

  {% if report.venues %}
  <div id="venue-filter">
    {% for venue in report.venues %}
    <label><input type="checkbox" class="venue-checkbox" value="{{ venue }}" checked> {{ venue }}</label>
    {% endfor %}
  </div>
  {% endif %}

  {% if report.day_sections %}
    {% for section in report.day_sections %}
      <section data-day-section>
        <h2>{{ short_date(section.date) }}</h2>
        <p><span class="show-count">{{ section.show_count }}</span> show(s), avg availability <span class="avg-pct">{{ "%.1f"|format(section.avg_availability_pct) }}</span>%</p>
        <div class="table-scroll">
          <table>
            {{ show_table_head(show_date=False) }}
            <tbody>
              {% for show in section.shows %}{{ show_row(show) }}{% endfor %}
            </tbody>
          </table>
        </div>
      </section>
    {% endfor %}
  {% else %}
    <p>No shows scanned.</p>
  {% endif %}

  <section data-most-available data-most-available-count="{{ most_available_count }}">
    <h2>Top Most Available</h2>
    <div class="table-scroll">
      <table>
        {{ show_table_head() }}
        <tbody></tbody>
      </table>
    </div>
  </section>

  {% if report.failed_calls %}
  <h2>Failed calls ({{ report.failed_calls|length }})</h2>
  <ul>
    {% for f in report.failed_calls %}
    <li>[{{ f.kind }}] {{ f.identifier }}: {{ f.error }}</li>
    {% endfor %}
  </ul>
  {% endif %}

  <script>
    document.body.addEventListener("click", function (event) {
      var link = event.target.closest("td.cell-book a");
      if (!link) return;
      var row = link.closest("tr");
      var performanceId = row && row.getAttribute("data-performance-id");
      if (!performanceId) return;
      document
        .querySelectorAll('tr[data-performance-id="' + performanceId + '"]')
        .forEach(function (matchedRow) {
          matchedRow.classList.add("row-clicked");
        });
    });
  </script>

  <script>
    var VENUE_FILTER_KEY = "shaw-venue-filter";
    var checkboxes = Array.prototype.slice.call(document.querySelectorAll(".venue-checkbox"));

    function selectedVenues() {
      return checkboxes.filter(function (cb) { return cb.checked; }).map(function (cb) { return cb.value; });
    }

    function rebuildMostAvailable() {
      var section = document.querySelector("[data-most-available]");
      if (!section) return;
      var tbody = section.querySelector("tbody");
      if (!tbody) return;

      var n = parseInt(section.getAttribute("data-most-available-count"), 10);
      var candidates = Array.prototype.slice
        .call(document.querySelectorAll("[data-day-section] tr[data-venue]"))
        .filter(function (row) { return !row.classList.contains("venue-hidden"); })
        .sort(function (a, b) {
          return parseFloat(b.getAttribute("data-availability")) - parseFloat(a.getAttribute("data-availability"));
        })
        .slice(0, n);

      tbody.innerHTML = "";
      candidates.forEach(function (row) {
        var clone = row.cloneNode(true);
        clone.classList.remove("venue-hidden");
        var dateCell = document.createElement("td");
        dateCell.textContent = row.getAttribute("data-date-label");
        clone.insertBefore(dateCell, clone.firstChild);
        tbody.appendChild(clone);
      });
    }

    function applyFilter() {
      var selected = selectedVenues();
      var selectedSet = {};
      selected.forEach(function (v) { selectedSet[v] = true; });

      document.querySelectorAll("tr[data-venue]").forEach(function (row) {
        var visible = !!selectedSet[row.getAttribute("data-venue")];
        row.classList.toggle("venue-hidden", !visible);
      });

      document.querySelectorAll("[data-day-section]").forEach(function (section) {
        var visibleRows = Array.prototype.slice
          .call(section.querySelectorAll("tr[data-venue]"))
          .filter(function (row) { return !row.classList.contains("venue-hidden"); });
        var countEl = section.querySelector(".show-count");
        var avgEl = section.querySelector(".avg-pct");
        if (countEl) countEl.textContent = visibleRows.length;
        if (avgEl) {
          if (visibleRows.length === 0) {
            avgEl.textContent = "n/a";
          } else {
            var total = visibleRows.reduce(function (sum, row) {
              return sum + parseFloat(row.getAttribute("data-availability"));
            }, 0);
            avgEl.textContent = (total / visibleRows.length).toFixed(1);
          }
        }
      });

      rebuildMostAvailable();
    }

    if (checkboxes.length) {
      try {
        var stored = JSON.parse(localStorage.getItem(VENUE_FILTER_KEY) || "null");
        if (Array.isArray(stored)) {
          var knownVenues = checkboxes.map(function (cb) { return cb.value; });
          var storedValid = stored.filter(function (v) { return knownVenues.indexOf(v) !== -1; });
          if (storedValid.length) {
            var storedSet = {};
            storedValid.forEach(function (v) { storedSet[v] = true; });
            checkboxes.forEach(function (cb) { cb.checked = !!storedSet[cb.value]; });
          }
        }
      } catch (e) {
        // Ignore malformed localStorage content and keep the default all-checked state.
      }

      checkboxes.forEach(function (cb) {
        cb.addEventListener("change", function () {
          localStorage.setItem(VENUE_FILTER_KEY, JSON.stringify(selectedVenues()));
          applyFilter();
        });
      });

      applyFilter();
    }
  </script>
</body>
</html>
